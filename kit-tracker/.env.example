# Copy to .env for local use, or set these as environment variables on Railway.
# NEVER commit a filled-in .env — it holds secrets.

# Shared team password. When set, every page requires this password to sign in.
# REQUIRED before putting Kit Tracker on a public URL. Leave unset for local
# localhost-only use.
KIT_TRACKER_PASSWORD=change-me-to-a-team-password

# Signs the login session cookie. Must be a long random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Where the SQLite database lives. On Railway, mount a Volume at /data and use
# the value below so data survives redeploys. Locally, leave this unset to use
# an instance-folder file.
# DATABASE_URL=sqlite:////data/kit_tracker.sqlite

# PORT is provided automatically by Railway; only set it for local overrides.
# PORT=5000
