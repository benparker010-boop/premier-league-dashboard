# Keep secret API keys out of GitHub — NEVER commit this
.streamlit/secrets.toml

# Python junk
__pycache__/
*.pyc

# World Cup result cache: TRACKED on purpose (public data, no secrets) — the
# GitHub Actions data refresh needs it so the model trains on real results and
# each run's re-fetch stays incremental. Only the .bak backup is ignored.
research/wc_matches.jsonl.bak

# Large PNG image originals — we commit the compressed .jpg versions instead
images/*.png
images/banners/*.png
